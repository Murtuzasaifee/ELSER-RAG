# OpenAI / MeshAPI
OPENAI_API_KEY=your_meshapi_key_here
OPENAI_BASE_URL=https://api.meshapi.ai/v1
OPENAI_MODEL=openai/gpt-5.4
OPENAI_ENRICHMENT_MODEL=openai/gpt-5.4-mini

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_DOCS_INDEX=elser_rag_docs
ELASTICSEARCH_CHUNKS_INDEX=elser_rag_chunks
ELSER_MODEL_ID=.elser_model_2

# Ingest
PDF_UPLOAD_DIR=/data/uploads
MAX_CHUNK_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# Retrieval
BM25_TOP_K=20

# Logging
LOG_LEVEL=INFO
